{
  "openapi": "3.1.0",
  "info": {
    "title": "EduTrack Finance & Payment Service API",
    "description": "Bộ API quản lý tài chính và thanh toán cho hệ thống EduTrack: tạo hóa đơn, tạo link thanh toán qua PayOS và xử lý webhook.",
    "contact": {
      "name": "EduTrack Team"
    },
    "license": {
      "name": "Internal Use"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "7. [Center] Mua Gói Đăng Ký (Buy Subscriptions)",
      "description": "Các API dành cho Quản lý Trung tâm (Center) để xem các gói cước đang bán và tiến hành thanh toán mua gói (gia hạn)"
    },
    {
      "name": "8. [Hệ thống] Webhook (Webhooks)",
      "description": "Các API nội bộ dùng để nhận phản hồi thanh toán thành công từ các đối tác thứ ba (như PayOS). FE KHÔNG DÙNG CÁC API NÀY!"
    },
    {
      "name": "6. [Parent] Thanh toán Hoá Đơn Học Phí (Payment Gateway)",
      "description": "Các API dành cho Phụ huynh bấm thanh toán hoá đơn. Sẽ sinh ra link để phụ huynh chuyển khoản quét mã QR (tích hợp PayOS)"
    },
    {
      "name": "1. [Admin] Dashboard",
      "description": "Tất cả các API thống kê biểu đồ dành riêng cho màn hình Dashboard của hệ thống Admin"
    },
    {
      "name": "3. [Center] Dashboard",
      "description": "Các API thống kê dành riêng cho màn hình Dashboard của Quản lý Trung tâm (Center Manager)"
    },
    {
      "name": "4. [Center] Quản lý Hoá Đơn Học Phí (Invoices)",
      "description": "Các API dành cho quản lý Trung tâm (Center) tạo và quản lý hoá đơn thu tiền học phí từ phụ huynh/học sinh"
    },
    {
      "name": "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)",
      "description": "CRUD các gói cước hệ thống (Ví dụ: Gói Cơ Bản 1 tháng, Gói Nâng Cao 1 năm) để các Center mua và sử dụng"
    },
    {
      "name": "5. [Parent/Center] Tra cứu Hoá Đơn Học Phí (Invoice Queries)",
      "description": "Các API dùng cho Phụ huynh (hoặc Center) xem lại lịch sử các hoá đơn theo học sinh"
    }
  ],
  "paths": {
    "/api/admin/subscription-packages/{id}": {
      "get": {
        "tags": [
          "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)"
        ],
        "summary": "Xem chi tiết 1 gói cước",
        "description": "Lấy thông tin của 1 gói cước dựa vào ID của gói đó. Dùng khi click vào chi tiết hoặc để điền dữ liệu vào form Edit.",
        "operationId": "getPackageById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionPackageResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)"
        ],
        "summary": "Cập nhật gói cước",
        "description": "Dùng khi Admin submit form chỉnh sửa. Có thể thay đổi name, description, price, durationMonths, và trạng thái isActive.",
        "operationId": "updatePackage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriptionPackageUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionPackageResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)"
        ],
        "summary": "Ẩn (Xóa mềm) gói cước",
        "description": "Không xóa hẳn khỏi database để giữ lịch sử thanh toán, chỉ đánh dấu isActive = false. Gói này sẽ không còn xuất hiện ở trang mua hàng của Center nữa.",
        "operationId": "deactivatePackage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/admin/subscription-packages/{id}/reactivate": {
      "put": {
        "tags": [
          "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)"
        ],
        "summary": "Mở lại (Kích hoạt lại) gói cước đã xóa mềm",
        "description": "Đánh dấu trạng thái isActive = true cho gói cước. Gói này sẽ hiển thị lại ở trang mua hàng của Center.",
        "operationId": "reactivatePackage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionPackageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/webhooks/payos": {
      "post": {
        "tags": [
          "8. [Hệ thống] Webhook (Webhooks)"
        ],
        "summary": "Nhận Webhook từ PayOS",
        "description": "Đường dẫn này được cung cấp cho PayOS. Khi người dùng chuyển khoản thành công, PayOS sẽ tự động gọi API này để hệ thống cập nhật trạng thái hóa đơn thành PAID.",
        "operationId": "handlePayOSWebhook",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PayOSWebhookRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/subscriptions/checkout": {
      "post": {
        "tags": [
          "7. [Center] Mua Gói Đăng Ký (Buy Subscriptions)"
        ],
        "summary": "Thanh toán mua gói cước (Tạo link quét QR PayOS)",
        "description": "Dùng khi Center chọn 1 gói cước và bấm 'Thanh toán'. API nhận packageId và centerId, tạo giao dịch và sinh ra link PayOS để Center quét QR thanh toán.",
        "operationId": "checkoutSubscription",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutSubscriptionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentLinkResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/payments/create-link": {
      "post": {
        "tags": [
          "6. [Parent] Thanh toán Hoá Đơn Học Phí (Payment Gateway)"
        ],
        "summary": "Tạo link thanh toán mã QR",
        "description": "Khi Phụ huynh bấm nút 'Thanh toán' ở 1 hoá đơn (có trạng thái PENDING). Gọi API này (truyền invoiceId), hệ thống sẽ trả về URL của cổng thanh toán PayOS. FE mở URL này lên (hoặc chuyển hướng) để phụ huynh quét QR thanh toán.",
        "operationId": "createPaymentLink",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentLinkResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/invoices": {
      "post": {
        "tags": [
          "4. [Center] Quản lý Hoá Đơn Học Phí (Invoices)"
        ],
        "summary": "Tạo một hoá đơn học phí mới",
        "description": "Dùng khi Center muốn phát hành hoá đơn cho học sinh. \n- Yêu cầu: studentId, parentId, classId, centerId, amount (số tiền).\n- Trạng thái mặc định: PENDING (Chưa thanh toán).\n- Có thể điền thêm dueDate (Hạn chót) và description (Ghi chú).",
        "operationId": "createInvoice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InvoiceCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/subscription-packages": {
      "get": {
        "tags": [
          "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)"
        ],
        "summary": "Lấy toàn bộ danh sách gói cước",
        "description": "Lấy tất cả các gói cước đang có (không phân biệt ACTIVE hay ẩn). Dùng để hiển thị lên bảng quản lý của Admin.",
        "operationId": "getAllPackages",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SubscriptionPackageResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "2. [Admin] Quản lý Gói Đăng Ký (Subscription Packages)"
        ],
        "summary": "Tạo mới gói cước",
        "description": "Dùng khi Admin submit form tạo mới. Các trường cần thiết: name, description, price, durationMonths. Mặc định gói tạo ra sẽ ở trạng thái isActive = true.",
        "operationId": "createPackage",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriptionPackageCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionPackageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/invoices/{id}/cancel": {
      "patch": {
        "tags": [
          "4. [Center] Quản lý Hoá Đơn Học Phí (Invoices)"
        ],
        "summary": "Hủy bỏ hoá đơn",
        "description": "Dùng khi Center muốn huỷ bỏ 1 hoá đơn (ví dụ: tạo sai). \n- API sẽ cập nhật trạng thái thành CANCELLED.\n- Lưu ý: Không thể huỷ nếu hoá đơn đã ở trạng thái PAID.",
        "operationId": "cancelInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/subscriptions/packages": {
      "get": {
        "tags": [
          "7. [Center] Mua Gói Đăng Ký (Buy Subscriptions)"
        ],
        "summary": "Xem danh sách các gói cước đang bán",
        "description": "Lấy tất cả các gói cước đang có trạng thái ACTIVE để hiển thị lên giao diện 'Mua gói' cho Center.",
        "operationId": "getAllPackages_1",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SubscriptionPackageResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/subscriptions/center/{centerId}": {
      "get": {
        "tags": [
          "7. [Center] Mua Gói Đăng Ký (Buy Subscriptions)"
        ],
        "summary": "Xem chi tiết gói đăng ký hiện tại của Center",
        "description": "Lấy thông tin gói đăng ký (gói cước hiện tại, giới hạn tài nguyên và ngày hết hạn) của một Center dựa trên ID.",
        "operationId": "getCenterSubscription",
        "parameters": [
          {
            "name": "centerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CenterSubscriptionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/students/{studentId}/invoices": {
      "get": {
        "tags": [
          "5. [Parent/Center] Tra cứu Hoá Đơn Học Phí (Invoice Queries)"
        ],
        "summary": "Lấy lịch sử hoá đơn của một học sinh",
        "description": "Truyền vào ID của học sinh. Trả về mảng danh sách tất cả các hoá đơn học phí liên quan đến học sinh này, bất kể trạng thái (PENDING, PAID, CANCELLED). Thường dùng ở app của Phụ Huynh.",
        "operationId": "getStudentInvoices",
        "parameters": [
          {
            "name": "studentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/InvoiceResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/invoices/{id}": {
      "get": {
        "tags": [
          "4. [Center] Quản lý Hoá Đơn Học Phí (Invoices)"
        ],
        "summary": "Xem chi tiết một hoá đơn",
        "description": "Lấy thông tin chi tiết của 1 hoá đơn bằng ID. FE dùng API này để hiển thị trang Chi tiết hoá đơn, kiểm tra trạng thái thanh toán (PENDING/PAID/CANCELLED), lấy tổng tiền, thời gian tạo, thời gian thanh toán...",
        "operationId": "getInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/center/{centerId}/dashboard/revenue": {
      "get": {
        "tags": [
          "3. [Center] Dashboard"
        ],
        "summary": "Lấy thống kê biểu đồ doanh thu học phí",
        "description": "Dùng để vẽ biểu đồ doanh thu theo tháng (tiền học phí thu từ phụ huynh/học sinh). Cần truyền vào ID của Center. Trả về tổng doanh thu đã thu (trạng thái PAID) và mảng doanh thu từng tháng trong năm hiện tại.",
        "operationId": "getRevenueStatistics",
        "parameters": [
          {
            "name": "centerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CenterDashboardRevenueResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/finance/center/{centerId}/dashboard/invoices": {
      "get": {
        "tags": [
          "3. [Center] Dashboard"
        ],
        "summary": "Lấy thống kê trạng thái hoá đơn học phí",
        "description": "Dùng để hiển thị các con số tổng quan về hoá đơn: Tổng số hoá đơn, số hoá đơn đã thu (PAID), chưa thu (PENDING), và đã huỷ (CANCELLED) của Center.",
        "operationId": "getInvoiceStatistics",
        "parameters": [
          {
            "name": "centerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CenterDashboardInvoiceStatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/dashboard/subscriptions": {
      "get": {
        "tags": [
          "1. [Admin] Dashboard"
        ],
        "summary": "Lấy thống kê trạng thái đăng ký của Center",
        "description": "Dùng để hiển thị các con số tổng quan: Tổng số Center, số Center đang hoạt động (ACTIVE), hết hạn (EXPIRED), và đã huỷ (CANCELLED).",
        "operationId": "getSubscriptionStatistics",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardSubscriptionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/dashboard/subscriptions/transactions": {
      "get": {
        "tags": [
          "1. [Admin] Dashboard"
        ],
        "summary": "Lấy danh sách các giao dịch mua gói cước thành công",
        "description": "Trả về danh sách lịch sử tất cả các giao dịch thanh toán mua gói cước thành công của các Center xếp theo thời gian mới nhất.",
        "operationId": "getSubscriptionTransactions",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AdminSubscriptionTransactionResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/dashboard/revenue": {
      "get": {
        "tags": [
          "1. [Admin] Dashboard"
        ],
        "summary": "Lấy thống kê biểu đồ doanh thu",
        "description": "Dùng để vẽ biểu đồ doanh thu theo tháng (từ các Center mua gói Subscription). Trả về tổng doanh thu và mảng dữ liệu từng tháng.",
        "operationId": "getRevenueStatistics_1",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardRevenueResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/dashboard/revenue/packages": {
      "get": {
        "tags": [
          "1. [Admin] Dashboard"
        ],
        "summary": "Lấy thống kê doanh thu theo từng gói cước đăng ký",
        "description": "Trả về danh sách doanh thu chi tiết gom nhóm theo từng loại gói cước (ví dụ: BASIC, STANDARD...) bao gồm tổng doanh thu và số lượng đã bán.",
        "operationId": "getRevenueByPackage",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AdminPackageRevenueStatsResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
